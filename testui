        local default  = opts.Default or Enum.KeyCode.Unknown
        local callback = opts.Callback or function() end
        local curKey   = default
        local listening = false

        local row = Row(26)
        New("TextLabel", {
            BackgroundTransparency = 1,
            Position               = UDim2.new(0, 9, 0, 0),
            Size                   = UDim2.new(1, -96, 1, 0),
            Text                   = label,
            TextColor3             = T.Text,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = zBase + 3,
            Parent                 = row,
        })
        local kbtn = New("TextButton", {
            BackgroundColor3 = T.Input,
            BorderSizePixel  = 0,
            AnchorPoint      = Vector2.new(0, 0.5),
            Position         = UDim2.new(1, -90, 0.5, 0),
            Size             = UDim2.new(0, 80, 0, 17),
            Text             = tostring(curKey):gsub("Enum%.KeyCode%.", ""),
            TextColor3       = T.Accent,
            TextSize         = 10,
            Font             = Enum.Font.GothamBold,
            AutoButtonColor  = false,
            ZIndex           = zBase + 3,
            Parent           = row,
        })
        Outline(kbtn, T.Border)
        kbtn.MouseButton1Click:Connect(function()
            listening = true
            kbtn.Text = "..."
            kbtn.TextColor3 = T.TextDim
        end)
        UserInputService.InputBegan:Connect(function(i, p)
            if listening and i.UserInputType == Enum.UserInputType.Keyboard then
                curKey = i.KeyCode
                kbtn.Text = tostring(curKey):gsub("Enum%.KeyCode%.", "")
                kbtn.TextColor3 = T.Accent
                listening = false
                pcall(callback, curKey)
            end
        end)

        local obj = {}
        function obj:Get() return curKey end
        return obj
    end

    -- ── ColorPicker ─────────────────────────────────────────
    function S:AddColorPicker(opts)
        opts = opts or {}
        local label    = opts.Name or "Color"
        local default  = opts.Default or Color3.fromRGB(139, 92, 246)
        local callback = opts.Callback or function() end

        local row = Row(26)
        New("TextLabel", {
            BackgroundTransparency = 1,
            Position               = UDim2.new(0, 9, 0, 0),
            Size                   = UDim2.new(1, -54, 1, 0),
            Text                   = label,
            TextColor3             = T.Text,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = zBase + 3,
            Parent                 = row,
        })

        local swatch = New("TextButton", {
            BackgroundColor3 = default,
            BorderSizePixel  = 0,
            AnchorPoint      = Vector2.new(0, 0.5),
            Position         = UDim2.new(1, -40, 0.5, 0),
            Size             = UDim2.new(0, 32, 0, 13),
            Text             = "",
            AutoButtonColor  = false,
            ZIndex           = zBase + 3,
            Parent           = row,
        })
        Grad(swatch, Color3.new(1,1,1), Color3.fromRGB(120,120,120), 90)
        Outline(swatch, T.Border)

        -- picker popup anchored relative to sec frame
        local picker = NewColorPicker(sec, default, 1, function(c, a)
            swatch.BackgroundColor3 = c
            pcall(callback, c, a)
        end, zBase + 30)
        local pw = picker:GetWindow()
        pw.Position = UDim2.new(0, 4, 1, 4)

        swatch.MouseButton1Click:Connect(function()
            pw.Visible = not pw.Visible
        end)
        -- close when clicking outside
        UserInputService.InputBegan:Connect(function(i)
            if pw.Visible and i.UserInputType == Enum.UserInputType.MouseButton1 then
                local mp = UserInputService:GetMouseLocation()
                local ap, as = pw.AbsolutePosition, pw.AbsoluteSize
                if not (mp.X >= ap.X and mp.X <= ap.X+as.X and
                        mp.Y >= ap.Y-36 and mp.Y-36 <= ap.Y-36+as.Y) then
                    if mp.X < swatch.AbsolutePosition.X or
                       mp.X > swatch.AbsolutePosition.X + swatch.AbsoluteSize.X then
                        pw.Visible = false
                    end
                end
            end
        end)

        local obj = {}
        function obj:Set(c, a) picker:Set(c, a) swatch.BackgroundColor3 = c end
        function obj:Get() return picker:GetColor() end
        return obj
    end

    return S
end

