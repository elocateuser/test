    -- ── Toggle ──────────────────────────────────────────────
    function S:AddToggle(opts)
        opts = opts or {}
        local label    = opts.Name or "Toggle"
        local default  = opts.Default ~= nil and opts.Default or false
        local keybind  = opts.Keybind
        local callback = opts.Callback or function() end
        local state    = default

        local row = Row(26)
        New("TextLabel", {
            BackgroundTransparency = 1,
            Position               = UDim2.new(0, 9, 0, 0),
            Size                   = UDim2.new(1, -52, 1, 0),
            Text                   = label,
            TextColor3             = T.Text,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = zBase + 3,
            Parent                 = row,
        })

        -- toggle pill
        local pill = New("Frame", {
            BackgroundColor3 = T.TglOff,
            BorderSizePixel  = 0,
            AnchorPoint      = Vector2.new(0, 0.5),
            Position         = UDim2.new(1, -36, 0.5, 0),
            Size             = UDim2.new(0, 28, 0, 13),
            ZIndex           = zBase + 3,
            Parent           = row,
        })
        local pillGrad = Grad(pill, T.TglOff, T.TglOff, 0)
        local knob = New("Frame", {
            BackgroundColor3 = T.TextDim,
            BorderSizePixel  = 0,
            AnchorPoint      = Vector2.new(0, 0.5),
            Position         = UDim2.new(0, 2, 0.5, 0),
            Size             = UDim2.new(0, 9, 0, 9),
            ZIndex           = zBase + 4,
            Parent           = pill,
        })

        if keybind then
            local kl = New("TextLabel", {
                BackgroundTransparency = 1,
                Position               = UDim2.new(1, -68, 0, 0),
                Size                   = UDim2.new(0, 28, 1, 0),
                Text                   = tostring(keybind):gsub("Enum%.KeyCode%.", ""),
                TextColor3             = T.TextMuted,
                TextSize               = 9,
                Font                   = Enum.Font.Gotham,
                ZIndex                 = zBase + 3,
                Parent                 = row,
            })
            AddKb(label, tostring(keybind):gsub("Enum%.KeyCode%.", ""))
            UserInputService.InputBegan:Connect(function(i, p)
                if p then return end
                if i.KeyCode == keybind then
                    state = not state
                    Apply()
                    pcall(callback, state)
                end
            end)
        end

        function Apply()
            if state then
                TweenService:Create(knob, TweenInfo.new(0.1), {
                    Position         = UDim2.new(0, 17, 0.5, 0),
                    BackgroundColor3 = Color3.new(1, 1, 1),
                }):Play()
                pillGrad.Color = ColorSequence.new(T.TglOnB, T.TglOn)
                TweenService:Create(pill, TweenInfo.new(0.1), {BackgroundColor3 = T.TglOn}):Play()
            else
                TweenService:Create(knob, TweenInfo.new(0.1), {
                    Position         = UDim2.new(0, 2, 0.5, 0),
                    BackgroundColor3 = T.TextDim,
                }):Play()
                pillGrad.Color = ColorSequence.new(T.TglOff, T.TglOff)
                TweenService:Create(pill, TweenInfo.new(0.1), {BackgroundColor3 = T.TglOff}):Play()
            end
        end
        Apply()

        pill.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                state = not state Apply() pcall(callback, state)
            end
        end)
        row.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                state = not state Apply() pcall(callback, state)
            end
        end)

        local obj = {}
        function obj:Set(v) state = v Apply() pcall(callback, state) end
        function obj:Get() return state end
        return obj
    end

    -- ── Slider ──────────────────────────────────────────────
    function S:AddSlider(opts)
        opts = opts or {}
        local label    = opts.Name or "Slider"
        local min      = opts.Min or 0
        local max      = opts.Max or 100
        local default  = opts.Default or min
        local suffix   = opts.Suffix or ""
        local decimals = opts.Decimals or 0
        local callback = opts.Callback or function() end
        local value    = math.clamp(default, min, max)
        local drag     = false

        local wrap = New("Frame", {
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1, 0, 0, 0),
            AutomaticSize          = Enum.AutomaticSize.Y,
            LayoutOrder            = seq,
            ZIndex                 = zBase + 2,
            Parent                 = items,
        })
        seq = seq + 1

        local top = New("Frame", {
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1, 0, 0, 20),
            ZIndex                 = zBase + 2,
            Parent                 = wrap,
        })
        New("TextLabel", {
            BackgroundTransparency = 1,
            Position               = UDim2.new(0, 9, 0, 0),
            Size                   = UDim2.new(1, -70, 1, 0),
            Text                   = label,
            TextColor3             = T.Text,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = zBase + 3,
            Parent                 = top,
        })
        local valLbl = New("TextLabel", {
            BackgroundTransparency = 1,
            Position               = UDim2.new(1, -62, 0, 0),
            Size                   = UDim2.new(0, 58, 1, 0),
            Text                   = tostring(value) .. suffix,
            TextColor3             = T.TextDim,
            TextSize               = 11,
            Font                   = Enum.Font.Gotham,
            TextXAlignment         = Enum.TextXAlignment.Right,
            ZIndex                 = zBase + 3,
            Parent                 = top,
        })

        local track = New("Frame", {
            BackgroundColor3 = T.SliderBg,
            BorderSizePixel  = 0,
            Position         = UDim2.new(0, 9, 0, 20),
            Size             = UDim2.new(1, -18, 0, 6),
            ZIndex           = zBase + 3,
            Parent           = wrap,
        })
        New("Frame", {
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1, 0, 0, 10),
            Position               = UDim2.new(0, 0, 0, 0),
            ZIndex                 = zBase + 2,
            Parent                 = wrap,
        })

        local fill = New("Frame", {
            BackgroundColor3 = T.SliderFg,
            BorderSizePixel  = 0,
            Size             = UDim2.new((value-min)/(max-min), 0, 1, 0),
            ZIndex           = zBase + 4,
            Parent           = track,
        })
        Grad(fill, T.SliderFgB, T.SliderFg, 0)

        local cur = New("Frame", {
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel  = 0,
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.new((value-min)/(max-min), 0, 0.5, 0),
            Size             = UDim2.new(0, 3, 1, 6),
            ZIndex           = zBase + 5,
            Parent           = track,
        })

        -- padding below
        New("Frame", {
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1, 0, 0, 6),
            ZIndex                 = zBase + 2,
            Position               = UDim2.new(0, 0, 0, 26),
            Parent                 = wrap,
        })

        local function Calc(mx)
            local abs = track.AbsolutePosition
            local sz  = track.AbsoluteSize
            local t   = math.clamp((mx - abs.X) / sz.X, 0, 1)
            local mult = 10 ^ decimals
            value = math.floor((min + t*(max-min)) * mult + 0.5) / mult
            fill.Size      = UDim2.new(t, 0, 1, 0)
            cur.Position   = UDim2.new(t, 0, 0.5, 0)
            valLbl.Text    = tostring(value) .. suffix
            pcall(callback, value)
        end

        track.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                drag = true Calc(i.Position.X)
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
                Calc(i.Position.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
        end)

        local obj = {}
        function obj:Set(v)
            value = math.clamp(v, min, max)
            local t = (value-min)/(max-min)
            fill.Size    = UDim2.new(t,0,1,0)
            cur.Position = UDim2.new(t,0,0.5,0)
            valLbl.Text  = tostring(value) .. suffix
        end
        function obj:Get() return value end
        return obj
    end

