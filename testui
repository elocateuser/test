                            BackgroundColor3 = Theme.Accent,
                            BorderSizePixel = 0,
                            Size = UDim2.new(1, 2, 1, 2),
                            Position = UDim2.new(0, -1, 0, -1),
                            ZIndex = 49,
                            Parent = dropList,
                        })
                        local sc = Create("ScrollingFrame", {
                            BackgroundTransparency = 1,
                            Size = UDim2.new(1, 0, 1, 0),
                            CanvasSize = UDim2.new(0, 0, 0, #items * 22),
                            ScrollBarThickness = 2,
                            ScrollBarImageColor3 = Theme.Accent,
                            BorderSizePixel = 0,
                            ZIndex = 51,
                            Parent = dropList,
                        })
                        for idx, item in ipairs(items) do
                            local itemBtn = Create("TextButton", {
                                BackgroundTransparency = 1,
                                Position = UDim2.new(0, 0, 0, (idx-1)*22),
                                Size = UDim2.new(1, 0, 0, 22),
                                Text = "  " .. tostring(item),
                                TextColor3 = Theme.TextDim,
                                TextSize = 11,
                                Font = Enum.Font.Gotham,
                                TextXAlignment = Enum.TextXAlignment.Left,
                                ZIndex = 52,
                                Parent = sc,
                            })
                            itemBtn.MouseEnter:Connect(function() itemBtn.BackgroundColor3 = Theme.TabActive itemBtn.BackgroundTransparency = 0 itemBtn.TextColor3 = Theme.Text end)
                            itemBtn.MouseLeave:Connect(function() itemBtn.BackgroundTransparency = 1 itemBtn.TextColor3 = Theme.TextDim end)
                            itemBtn.MouseButton1Click:Connect(function()
                                selected = item
                                dropBtn.Text = "  " .. tostring(item)
                                dropOpen = false
                                if dropList then dropList:Destroy() dropList = nil end
                                pcall(callback, selected)
                            end)
                        end
                    end
                end)

                local Dropdown = {}
                function Dropdown:Set(val) selected = val dropBtn.Text = "  " .. tostring(val) pcall(callback, val) end
                function Dropdown:Get() return selected end
                function Dropdown:Refresh(newItems)
                    items = newItems
                    if dropList then dropList:Destroy() dropList = nil dropOpen = false end
                end
                return Dropdown
            end

            -- ---- TEXT INPUT ----
            function Section:AddInput(opts)
                opts = opts or {}
                local label = opts.Name or "Input"
                local placeholder = opts.Placeholder or ""
                local default = opts.Default or ""
                local callback = opts.Callback or function() end

                itemCount = itemCount + 1
                local wrap = Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 46),
                    LayoutOrder = itemCount,
                    ZIndex = 14,
                    Parent = itemContainer,
                })
                Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 4),
                    Size = UDim2.new(1, -20, 0, 16),
                    Text = label,
                    TextColor3 = Theme.Text,
                    TextSize = 11,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 15,
                    Parent = wrap,
                })
                local inputBox = Create("TextBox", {
                    BackgroundColor3 = Theme.InputBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 8, 0, 22),
                    Size = UDim2.new(1, -16, 0, 20),
                    Text = default,
                    PlaceholderText = placeholder,
                    PlaceholderColor3 = Theme.TextDisabled,
                    TextColor3 = Theme.Text,
                    TextSize = 11,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 15,
                    ClearTextOnFocus = false,
                    Parent = wrap,
                })
                Create("UIPadding", {PaddingLeft = UDim.new(0, 6), Parent = inputBox})
                Create("Frame", {
                    BackgroundColor3 = Theme.Border,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 2, 1, 2),
                    Position = UDim2.new(0, -1, 0, -1),
                    ZIndex = 14,
                    Parent = inputBox,
                })
                inputBox:GetPropertyChangedSignal("Text"):Connect(function()
                    pcall(callback, inputBox.Text)
                end)

                local Input = {}
                function Input:Set(val) inputBox.Text = val end
                function Input:Get() return inputBox.Text end
                return Input
            end

            -- ---- LABEL ----
            function Section:AddLabel(opts)
                opts = opts or {}
                local text = type(opts) == "string" and opts or (opts.Text or "Label")

                itemCount = itemCount + 1
                Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 0),
                    Size = UDim2.new(1, -20, 0, 24),
                    Text = text,
                    TextColor3 = Theme.TextDim,
                    TextSize = 11,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextWrapped = true,
                    LayoutOrder = itemCount,
                    ZIndex = 15,
                    Parent = itemContainer,
                })
            end

            -- ---- KEYBIND ----
            function Section:AddKeybind(opts)
                opts = opts or {}
                local label = opts.Name or "Keybind"
                local default = opts.Default or Enum.KeyCode.Unknown
                local callback = opts.Callback or function() end

                itemCount = itemCount + 1
                local currentKey = default
                local listening = false

                local row = Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 28),
                    LayoutOrder = itemCount,
                    ZIndex = 14,
                    Parent = itemContainer,
                })
                Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 0),
                    Size = UDim2.new(1, -90, 1, 0),
                    Text = label,
                    TextColor3 = Theme.Text,
                    TextSize = 11,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 15,
                    Parent = row,
                })
                local keyBtn = Create("TextButton", {
                    BackgroundColor3 = Theme.InputBg,
                    BorderSizePixel = 0,
                    Position = UDim2.new(1, -84, 0.5, -10),
                    Size = UDim2.new(0, 76, 0, 18),
                    Text = tostring(currentKey):gsub("Enum.KeyCode.", ""),
                    TextColor3 = Theme.Accent,
                    TextSize = 10,
                    Font = Enum.Font.GothamBold,
                    ZIndex = 15,
                    Parent = row,
                })
                Create("Frame", {
                    BackgroundColor3 = Theme.Border,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 2, 1, 2),
                    Position = UDim2.new(0, -1, 0, -1),
                    ZIndex = 14,
                    Parent = keyBtn,
                })

                keyBtn.MouseButton1Click:Connect(function()
                    listening = true
                    keyBtn.Text = "..."
                    keyBtn.TextColor3 = Theme.Text
                end)
                UserInputService.InputBegan:Connect(function(inp, proc)
                    if listening and inp.UserInputType == Enum.UserInputType.Keyboard then
                        currentKey = inp.KeyCode
                        keyBtn.Text = tostring(currentKey):gsub("Enum.KeyCode.", "")
                        keyBtn.TextColor3 = Theme.Accent
                        listening = false
                        pcall(callback, currentKey)
                    end
                end)

                local KB = {}
                function KB:Get() return currentKey end
                return KB
            end

            -- ---- COLOR PICKER ----
            function Section:AddColorPicker(opts)
                opts = opts or {}
                local label = opts.Name or "Color"
                local default = opts.Default or Color3.fromRGB(120, 80, 200)
                local callback = opts.Callback or function() end

                itemCount = itemCount + 1
                local currentColor = default

                local row = Create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 28),
                    LayoutOrder = itemCount,
                    ZIndex = 14,
                    Parent = itemContainer,
                })
                Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 0),
                    Size = UDim2.new(1, -60, 1, 0),
                    Text = label,
                    TextColor3 = Theme.Text,
                    TextSize = 11,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 15,
                    Parent = row,
                })
                local colorSwatch = Create("TextButton", {
                    BackgroundColor3 = currentColor,
                    BorderSizePixel = 0,
                    Position = UDim2.new(1, -36, 0.5, -9),
                    Size = UDim2.new(0, 28, 0, 16),
                    Text = "",
                    ZIndex = 15,
                    Parent = row,
                })
                Create("Frame", {
                    BackgroundColor3 = Theme.Border,
                    BorderSizePixel = 0,
                    Size = UDim2.new(1, 2, 1, 2),
                    Position = UDim2.new(0, -1, 0, -1),
                    ZIndex = 14,
                    Parent = colorSwatch,
                })

                local picker = CreateColorWheel(mainWindow, 200, 100, currentColor, function(c)
                    currentColor = c
                    colorSwatch.BackgroundColor3 = c
                    pcall(callback, c)
                end)
                MakeDraggable(picker, picker, function() return isOpen end)

                colorSwatch.MouseButton1Click:Connect(function()
                    picker.Visible = not picker.Visible
                end)

                local CP = {}
                function CP:Set(c) currentColor = c colorSwatch.BackgroundColor3 = c pcall(callback, c) end
                function CP:Get() return currentColor end
                return CP
            end

            return Section
        end

        function Tab:AddSection(sectionName)
            return Tab:_AddSection(sectionName, tabContent)
        end

        return Tab
    end

    function Window:ShowPlayerList(vis)
        playerListFrame.Visible = vis
    end

    function Window:AddKeybind(name, key)
        AddKeybind(name, key)
    end

    return Window
end

