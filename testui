                    FillDirection = Enum.FillDirection.Horizontal,
                    VerticalAlignment = Enum.VerticalAlignment.Center,
                    Padding = UDim.new(0, 1),
                    Parent = subTabBar
                })

                local subContent = Create("Frame", {
                    Name = "SubContent",
                    Size = UDim2.new(1, 0, 1, -26),
                    Position = UDim2.new(0, 0, 0, 26),
                    BackgroundTransparency = 1,
                    ZIndex = 13,
                    Parent = containerFrame
                })

                function SubContainer:CreateSubTab(stName)
                    local SubTab = {}
                    SubTab.Sections = {}

                    local stBtn = Create("TextButton", {
                        Name = "SubTab_"..stName,
                        Size = UDim2.new(0, 80, 0, 24),
                        BackgroundColor3 = Theme.TabBg,
                        BorderSizePixel = 0,
                        Text = stName,
                        TextColor3 = Theme.TextDark,
                        TextSize = 11,
                        Font = Enum.Font.Gotham,
                        ZIndex = 15,
                        LayoutOrder = #SubContainer.Tabs + 1,
                        Parent = subTabBar
                    })

                    local stGrad = AddGradient(stBtn, ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Theme.Accent),
                        ColorSequenceKeypoint.new(1, Theme.AccentDark)
                    }), 90)
                    stGrad.Transparency = NumberSequence.new(1)

                    -- Bottom indicator
                    local stBar = Create("Frame", {
                        Size = UDim2.new(1, 0, 0, 2),
                        Position = UDim2.new(0, 0, 1, -2),
                        BackgroundColor3 = Theme.Accent,
                        BorderSizePixel = 0,
                        ZIndex = 16,
                        Visible = false,
                        Parent = stBtn
                    })
                    AddGradient(stBar, ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Theme.AccentLight),
                        ColorSequenceKeypoint.new(1, Theme.Accent)
                    }), 0)

                    -- Subtab scroll content
                    local stScroll = Create("ScrollingFrame", {
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        BorderSizePixel = 0,
                        ScrollBarThickness = 3,
                        ScrollBarImageColor3 = Theme.Accent,
                        ZIndex = 14,
                        Visible = false,
                        Parent = subContent
                    })
                    local stLayout = Create("UIListLayout", {
                        SortOrder = Enum.SortOrder.LayoutOrder,
                        Padding = UDim.new(0, 6),
                        Parent = stScroll
                    })
                    Create("UIPadding", {
                        PaddingTop = UDim.new(0, 6),
                        PaddingLeft = UDim.new(0, 4),
                        PaddingRight = UDim.new(0, 4),
                        PaddingBottom = UDim.new(0, 6),
                        Parent = stScroll
                    })

                    SubTab.Content = stScroll
                    SubTab.Layout = stLayout
                    -- Attach CreateSection to SubTab using same logic as Tab
                    local stTab = setmetatable({}, {__index = Tab})
                    stTab.Content = stScroll
                    stTab.ContentLayout = stLayout

                    function SubTab:CreateSection(secName)
                        return Tab.CreateSection(stTab, secName)
                    end

                    local function SetSubActive(active)
                        stGrad.Transparency = active and NumberSequence.new(0) or NumberSequence.new(1)
                        stBar.Visible = active
                        stBtn.TextColor3 = active and Theme.Text or Theme.TextDark
                        stBtn.Font = active and Enum.Font.GothamBold or Enum.Font.Gotham
                        stScroll.Visible = active
                    end

                    stBtn.MouseButton1Click:Connect(function()
                        if SubContainer.ActiveTab then
                            SubContainer.ActiveTab.SetActive(false)
                        end
                        SubContainer.ActiveTab = SubTab
                        SubTab.SetActive = SetSubActive
                        SetSubActive(true)
                    end)

                    SubTab.SetActive = SetSubActive
                    table.insert(SubContainer.Tabs, SubTab)

                    if #SubContainer.Tabs == 1 then
                        SubContainer.ActiveTab = SubTab
                        SetSubActive(true)
                    end

                    return SubTab
                end

                return SubContainer
            end

            table.insert(Tab.Sections, Section)
            return Section
        end

        table.insert(Window.Tabs, Tab)
        return Tab
    end

    table.insert(Library.Windows, Window)
    return Window
end

