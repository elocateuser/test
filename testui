    })

    -- Value slider (brightness)
    local valBg = Create("Frame", {
        BackgroundColor3 = Theme.SliderBg,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 10, 0, SIZE + 16),
        Size = UDim2.new(0, SIZE, 0, 14),
