                    Name = "ToggleBg",
                    Size = UDim2.new(0, 36, 0, 16),
                    Position = UDim2.new(1, -38, 0.5, -8),
                    BackgroundColor3 = value and Theme.ToggleOn or Theme.ToggleOff,
                    BorderSizePixel = 0,
                    ZIndex = 15,
                    Parent = rowFrame
                })
                AddStroke(toggleBg, Theme.Border, 1)

                local toggleGrad = AddGradient(toggleBg, ColorSequence.new({
                    ColorSequenceKeypoint.new(0, value and Theme.AccentLight or Color3.fromRGB(55, 55, 70)),
                    ColorSequenceKeypoint.new(1, value and Theme.AccentDark  or Color3.fromRGB(35, 35, 48)),
                }), 0)

                local toggleKnob = Create("Frame", {
                    Name = "Knob",
                    Size = UDim2.new(0, 12, 0, 12),
                    Position = value and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6),
                    BackgroundColor3 = Color3.new(1,1,1),
                    BorderSizePixel = 0,
                    ZIndex = 16,
                    Parent = toggleBg
                })

                local function SetToggle(v, skipCallback)
                    value = v
                    Toggle.Value = v
                    Tween(toggleBg, {BackgroundColor3 = v and Theme.ToggleOn or Theme.ToggleOff}, 0.12)
                    toggleGrad.Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, v and Theme.AccentLight or Color3.fromRGB(55, 55, 70)),
                        ColorSequenceKeypoint.new(1, v and Theme.AccentDark  or Color3.fromRGB(35, 35, 48)),
                    })
                    Tween(toggleKnob, {
                        Position = v and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)
                    }, 0.12)
                    if flag then Library.Flags[flag] = v end
                    if callback and not skipCallback then callback(v) end
                end

                toggleBg.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        SetToggle(not value)
                    end
                end)
                rowFrame.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        SetToggle(not value)
                    end
                end)

                if flag then
                    Library.Flags[flag] = value
                end
                Toggle.Set = SetToggle
                table.insert(Section.Elements, Toggle)
                return Toggle
            end

            -- ==================== SLIDER ====================
            function Section:AddSlider(name, config2, callback, flag)
                config2 = config2 or {}
                local min = config2.Min or 0
                local max = config2.Max or 100
                local default2 = config2.Default or min
                local suffix = config2.Suffix or ""
                local value = default2
                local Slider = {Value = value}

                local rowFrame = Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 38),
                    BackgroundTransparency = 1,
                    ZIndex = 14,
                    LayoutOrder = #Section.Elements + 1,
                    Parent = sectionFrame
                })

                -- Top row: name + value
                local nameLabel = Create("TextLabel", {
                    Size = UDim2.new(0.7, 0, 0, 18),
                    BackgroundTransparency = 1,
                    Text = name,
                    TextColor3 = Theme.Text,
                    TextSize = 12,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 15,
                    Parent = rowFrame
                })
                local valLabel = Create("TextLabel", {
                    Size = UDim2.new(0.3, 0, 0, 18),
                    BackgroundTransparency = 1,
                    Text = tostring(value) .. suffix,
                    TextColor3 = Theme.TextDark,
                    TextSize = 11,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    ZIndex = 15,
                    Parent = rowFrame
                })

                local sliderBg = Create("Frame", {
                    Size = UDim2.new(1, 0, 0, 8),
                    Position = UDim2.new(0, 0, 0, 22),
                    BackgroundColor3 = Theme.SliderBg,
                    BorderSizePixel = 0,
                    ZIndex = 15,
                    Parent = rowFrame
                })
                AddStroke(sliderBg, Theme.Border, 1)

                local pct = (value - min) / (max - min)
                local sliderFill = Create("Frame", {
                    Size = UDim2.new(pct, 0, 1, 0),
                    BackgroundColor3 = Theme.SliderFill,
                    BorderSizePixel = 0,
                    ZIndex = 16,
                    Parent = sliderBg
                })
                AddGradient(sliderFill, ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Theme.AccentLight),
                    ColorSequenceKeypoint.new(1, Theme.Accent)
                }), 0)

                -- Knob
                local sliderKnob = Create("Frame", {
                    Size = UDim2.new(0, 8, 0, 14),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new(pct, 0, 0.5, 0),
                    BackgroundColor3 = Theme.AccentLight,
                    BorderSizePixel = 0,
                    ZIndex = 17,
                    Parent = sliderBg
                })
                AddStroke(sliderKnob, Color3.fromRGB(0,0,0), 1)

                local dragging = false
                local function SetSlider(v)
                    v = math.clamp(v, min, max)
                    if config2.Int then v = math.floor(v) end
                    value = v
                    Slider.Value = v
                    local p = (v - min) / (max - min)
                    sliderFill.Size = UDim2.new(p, 0, 1, 0)
                    sliderKnob.Position = UDim2.new(p, 0, 0.5, 0)
                    valLabel.Text = tostring(v) .. suffix
                    if flag then Library.Flags[flag] = v end
                    if callback then callback(v) end
                end

                sliderBg.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        local abs = sliderBg.AbsolutePosition
                        local sz  = sliderBg.AbsoluteSize
                        local pctN = math.clamp((inp.Position.X - abs.X) / sz.X, 0, 1)
                        SetSlider(min + (max - min) * pctN)
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                        local abs = sliderBg.AbsolutePosition
                        local sz  = sliderBg.AbsoluteSize
                        local pctN = math.clamp((inp.Position.X - abs.X) / sz.X, 0, 1)
                        SetSlider(min + (max - min) * pctN)
