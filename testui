-- Utility functions
local function Create(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then
            inst[k] = v
        end
    end
    for _, child in ipairs(children or {}) do
        child.Parent = inst
    end
    if props and props.Parent then
        inst.Parent = props.Parent
    end
    return inst
end

local function MakeBorder(parent, color, thickness)
    thickness = thickness or 1
    local frame = Create("Frame", {
        BackgroundColor3 = color or Theme.Border,
        BorderSizePixel = 0,
        Size = UDim2.new(1, thickness*2, 1, thickness*2),
        Position = UDim2.new(0, -thickness, 0, -thickness),
        ZIndex = parent.ZIndex - 1,
        Parent = parent.Parent,
    })
    parent.Parent = frame
    return frame
end

local function Gradient(frame, c1, c2, rotation)
    local g = Create("UIGradient", {
        Color = ColorSequence.new(c1, c2),
        Rotation = rotation or 0,
        Parent = frame,
    })
    return g
end

local function MakeDraggable(frame, handle, canDragFn)
    handle = handle or frame
    local dragging = false
    local dragStart, startPos

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if canDragFn and not canDragFn() then return end
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

local function AutoSize(frame)
    local layout = frame:FindFirstChildOfClass("UIListLayout")
    if layout then
        local function update()
            frame.Size = UDim2.new(frame.Size.X.Scale, frame.Size.X.Offset, 0, layout.AbsoluteContentSize.Y)
        end
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(update)
        update()
    end
end

-- HSV Color Wheel helper
local function HSVtoRGB(h, s, v)
    if s == 0 then return v, v, v end
    local i = math.floor(h * 6)
    local f = h * 6 - i
    local p = v * (1 - s)
    local q = v * (1 - f * s)
    local t = v * (1 - (1 - f) * s)
    i = i % 6
    if i == 0 then return v, t, p
    elseif i == 1 then return q, v, p
    elseif i == 2 then return p, v, t
    elseif i == 3 then return p, q, v
    elseif i == 4 then return t, p, v
    elseif i == 5 then return v, p, q
    end
end

