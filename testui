-- Utility
local function Create(class, props)
    local obj = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then
            obj[k] = v
        end
    end
    if props.Parent then obj.Parent = props.Parent end
    return obj
end

local function AddCorner(parent, radius)
    local c = Create("UICorner", {CornerRadius = UDim.new(0, radius or 0), Parent = parent})
    return c
end

local function AddGradient(parent, colorSeq, rotation)
    return Create("UIGradient", {
        Color = colorSeq or ColorSequence.new({
            ColorSequenceKeypoint.new(0, Theme.Accent),
            ColorSequenceKeypoint.new(1, Theme.AccentDark)
        }),
        Rotation = rotation or 90,
        Parent = parent
    })
end

local function AddStroke(parent, color, thickness)
    return Create("UIStroke", {
        Color = color or Theme.Border,
        Thickness = thickness or 1,
        Parent = parent
    })
end

local function Tween(obj, props, duration)
    local info = TweenInfo.new(duration or 0.15, Enum.EasingStyle.Linear)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function GetTextSize(text, size, font, max)
    return game:GetService("TextService"):GetTextSize(text, size, font, max or Vector2.new(math.huge, math.huge))
end

