local function CreateColorPicker(parent, defaultColor, callback)
    local pickerOpen = false
    local currentColor = defaultColor or Color3.fromRGB(255, 100, 100)
    local currentH, currentS, currentV = Color3.toHSV(currentColor)

    -- Preview button
    local previewBtn = Create("Frame", {
        Name = "ColorPreview",
        Size = UDim2.new(0, 22, 0, 14),
        BackgroundColor3 = currentColor,
        BorderSizePixel = 0,
        ZIndex = 10,
        Parent = parent
    })
    AddStroke(previewBtn, Theme.Border, 1)

    -- Picker popup
    local pickerFrame = Create("Frame", {
        Name = "ColorPicker",
        Size = UDim2.new(0, 200, 0, 200),
        Position = UDim2.new(0, 0, 1, 4),
        BackgroundColor3 = Theme.Secondary,
        BorderSizePixel = 0,
        ZIndex = 200,
        Visible = false,
        Parent = parent
    })
    AddStroke(pickerFrame, Theme.Border, 1)

    -- Hue bar (vertical rainbow)
    local hueBar = Create("Frame", {
        Name = "HueBar",
        Size = UDim2.new(0, 16, 1, -40),
        Position = UDim2.new(1, -24, 0, 8),
        BackgroundColor3 = Color3.new(1,1,1),
        BorderSizePixel = 0,
        ZIndex = 201,
        ClipsDescendants = true,
        Parent = pickerFrame
    })
    -- Rainbow gradient
    local hueGrad = Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,    Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.167,Color3.fromRGB(255, 255, 0)),
            ColorSequenceKeypoint.new(0.333,Color3.fromRGB(0, 255, 0)),
            ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(0, 255, 255)),
            ColorSequenceKeypoint.new(0.667,Color3.fromRGB(0, 0, 255)),
            ColorSequenceKeypoint.new(0.833,Color3.fromRGB(255, 0, 255)),
            ColorSequenceKeypoint.new(1,    Color3.fromRGB(255, 0, 0)),
        }),
        Rotation = 90,
        Parent = hueBar
    })
    AddStroke(hueBar, Theme.Border, 1)

    -- Hue cursor
    local hueCursor = Create("Frame", {
        Name = "HueCursor",
        Size = UDim2.new(1, 4, 0, 3),
        Position = UDim2.new(0, -2, 0, 0),
        BackgroundColor3 = Color3.new(1,1,1),
        BorderSizePixel = 0,
        ZIndex = 202,
        Parent = hueBar
    })

    -- SV square (saturation-value)
    local svSquare = Create("Frame", {
        Name = "SVSquare",
        Size = UDim2.new(1, -32, 1, -40),
        Position = UDim2.new(0, 8, 0, 8),
        BackgroundColor3 = Color3.fromHSV(currentH, 1, 1),
        BorderSizePixel = 0,
        ZIndex = 201,
        ClipsDescendants = true,
        Parent = pickerFrame
    })
    AddStroke(svSquare, Theme.Border, 1)

    -- White gradient (left to right: white to transparent)
    Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
            ColorSequenceKeypoint.new(1, Color3.new(1,1,1))
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(1, 1)
        }),
        Rotation = 0,
        Parent = svSquare
    })

    -- Black gradient (top to bottom: transparent to black)
    local blackOverlay = Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.new(0,0,0),
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        ZIndex = 202,
        Parent = svSquare
    })
    Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.new(0,0,0)),
            ColorSequenceKeypoint.new(1, Color3.new(0,0,0))
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0)
        }),
        Rotation = 90,
        Parent = blackOverlay
    })

    -- SV cursor
    local svCursor = Create("Frame", {
        Name = "SVCursor",
        Size = UDim2.new(0, 8, 0, 8),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(currentS, 0, 1 - currentV, 0),
        BackgroundColor3 = Color3.new(1,1,1),
        BorderSizePixel = 0,
        ZIndex = 204,
        Parent = svSquare
    })
    AddStroke(svCursor, Color3.new(0,0,0), 1)

    -- Hex input
    local hexInput = Create("TextBox", {
        Name = "HexInput",
        Size = UDim2.new(1, -32, 0, 20),
        Position = UDim2.new(0, 8, 1, -28),
        BackgroundColor3 = Theme.Tertiary,
        BorderSizePixel = 0,
        Text = "#" .. string.format("%02X%02X%02X",
            math.floor(currentColor.R*255),
            math.floor(currentColor.G*255),
            math.floor(currentColor.B*255)),
        TextColor3 = Theme.Text,
        TextSize = 11,
        Font = Enum.Font.Code,
        ZIndex = 203,
        ClearTextOnFocus = false,
        Parent = pickerFrame
    })
    AddStroke(hexInput, Theme.Border, 1)

    local function UpdateColor()
        local col = Color3.fromHSV(currentH, currentS, currentV)
        currentColor = col
        previewBtn.BackgroundColor3 = col
        svSquare.BackgroundColor3 = Color3.fromHSV(currentH, 1, 1)
        svCursor.Position = UDim2.new(currentS, 0, 1 - currentV, 0)
        hueCursor.Position = UDim2.new(0, -2, currentH, 0)
        hexInput.Text = "#" .. string.format("%02X%02X%02X",
            math.floor(col.R*255), math.floor(col.G*255), math.floor(col.B*255))
        if callback then callback(col) end
    end

    -- SV interaction
    local svDragging = false
    svSquare.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = true end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if svDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local abs = svSquare.AbsolutePosition
            local size = svSquare.AbsoluteSize
            local x = math.clamp((inp.Position.X - abs.X) / size.X, 0, 1)
            local y = math.clamp((inp.Position.Y - abs.Y) / size.Y, 0, 1)
            currentS = x
            currentV = 1 - y
            UpdateColor()
        end
    end)

    -- Hue interaction
    local hueDragging = false
    hueBar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then hueDragging = true end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then hueDragging = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if hueDragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local abs = hueBar.AbsolutePosition
            local size = hueBar.AbsoluteSize
            local y = math.clamp((inp.Position.Y - abs.Y) / size.Y, 0, 1)
            currentH = y
            UpdateColor()
        end
    end)

    -- Hex input
    hexInput.FocusLost:Connect(function(enter)
        if enter then
            local hex = hexInput.Text:gsub("#", "")
            if #hex == 6 then
                local r = tonumber(hex:sub(1,2), 16)
                local g = tonumber(hex:sub(3,4), 16)
                local b = tonumber(hex:sub(5,6), 16)
                if r and g and b then
                    local col = Color3.fromRGB(r, g, b)
                    currentH, currentS, currentV = Color3.toHSV(col)
                    UpdateColor()
                end
            end
        end
    end)

    -- Toggle open/close
    previewBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            pickerOpen = not pickerOpen
            pickerFrame.Visible = pickerOpen
        end
    end)

    UpdateColor()
    return previewBtn, pickerFrame, function() return currentColor end
end

