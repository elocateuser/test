    AddStroke(loginBtn, Theme.Border, 1)
    loginBtn.MouseEnter:Connect(function() Tween(loginBtn, {BackgroundColor3 = Theme.Accent}, 0.1) end)
    loginBtn.MouseLeave:Connect(function() Tween(loginBtn, {BackgroundColor3 = Theme.Tertiary}, 0.1) end)
    loginBtn.MouseButton1Click:Connect(function()
        onLogin(userInput.Text, passInput.Text)
    end)

    -- Exit button
    local exitBtn = Create("TextButton", {
        Size = UDim2.new(1, -16, 0, 26),
        Position = UDim2.new(0, 8, 0, 180),
        BackgroundColor3 = Theme.Tertiary,
        BorderSizePixel = 0,
        Text = "Exit",
        TextColor3 = Theme.Text,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        ZIndex = 503,
        Parent = loginPanel
    })
    AddStroke(exitBtn, Theme.Border, 1)
    exitBtn.MouseEnter:Connect(function() Tween(exitBtn, {BackgroundColor3 = Color3.fromRGB(160, 40, 40)}, 0.1) end)
    exitBtn.MouseLeave:Connect(function() Tween(exitBtn, {BackgroundColor3 = Theme.Tertiary}, 0.1) end)
    exitBtn.MouseButton1Click:Connect(function()
        loaderFrame:Destroy()
    end)

    -- Save credentials checkbox
    local saveFrame = Create("Frame", {
        Size = UDim2.new(1, -16, 0, 18),
        Position = UDim2.new(0, 8, 0, 212),
        BackgroundTransparency = 1,
        ZIndex = 503,
        Parent = loginPanel
    })
    local saveCB = Create("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(0, 0, 0.5, -6),
        BackgroundColor3 = Theme.Tertiary,
        BorderSizePixel = 0,
        ZIndex = 504,
        Parent = saveFrame
    })
    AddStroke(saveCB, Theme.Border, 1)
    local saveCBCheck = Create("Frame", {
        Size = UDim2.new(0, 8, 0, 8),
        Position = UDim2.new(0.5, -4, 0.5, -4),
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        ZIndex = 505,
        Visible = false,
        Parent = saveCB
    })
    local saveEnabled = false
    saveCB.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            saveEnabled = not saveEnabled
            saveCBCheck.Visible = saveEnabled
        end
    end)
    Create("TextLabel", {
        Size = UDim2.new(1, -18, 1, 0),
        Position = UDim2.new(0, 18, 0, 0),
        BackgroundTransparency = 1,
        Text = "Save credentials",
        TextColor3 = Theme.TextDark,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 504,
        Parent = saveFrame
    })

    -- ---- INFO PANEL ----
    local infoPanel = Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = 502,
        Parent = rightPanel
    })
    Create("TextLabel", {
        Size = UDim2.new(1, -16, 0, 20),
        Position = UDim2.new(0, 8, 0, 12),
        BackgroundTransparency = 1,
        Text = title .. " " .. version,
        TextColor3 = Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 503,
        Parent = infoPanel
    })
    Create("TextLabel", {
        Size = UDim2.new(1, -16, 0, 50),
        Position = UDim2.new(0, 8, 0, 36),
        BackgroundTransparency = 1,
        Text = desc,
        TextColor3 = Theme.TextDark,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        ZIndex = 503,
        Parent = infoPanel
    })
    Create("TextLabel", {
        Size = UDim2.new(1, -16, 0, 16),
        Position = UDim2.new(0, 8, 0, 92),
        BackgroundTransparency = 1,
        Text = "Owners",
        TextColor3 = Theme.TextDark,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 503,
        Parent = infoPanel
    })
    Create("TextLabel", {
        Size = UDim2.new(1, -16, 0, 16),
        Position = UDim2.new(0, 8, 0, 108),
        BackgroundTransparency = 1,
        Text = table.concat(owners, ", "),
        TextColor3 = Theme.AccentLight,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 503,
        Parent = infoPanel
    })
    local discordBtn = Create("TextButton", {
        Size = UDim2.new(1, -16, 0, 26),
        Position = UDim2.new(0, 8, 0, 134),
        BackgroundColor3 = Color3.fromRGB(88, 101, 242),
        BorderSizePixel = 0,
        Text = "Join Discord",
        TextColor3 = Color3.new(1,1,1),
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        ZIndex = 503,
        Parent = infoPanel
    })
    AddStroke(discordBtn, Color3.fromRGB(60, 70, 200), 1)
    discordBtn.MouseEnter:Connect(function() Tween(discordBtn, {BackgroundColor3 = Color3.fromRGB(110, 124, 255)}, 0.1) end)
    discordBtn.MouseLeave:Connect(function() Tween(discordBtn, {BackgroundColor3 = Color3.fromRGB(88, 101, 242)}, 0.1) end)
    discordBtn.MouseButton1Click:Connect(function()
        if setclipboard then
            setclipboard(discord)
            Library:Notify("Discord", "Link copied to clipboard!", 3, "info")
        end
    end)

    -- Make tabs
    local loginSetActive = MakeLoaderTab("Login", loginPanel, 1)
    local infoSetActive  = MakeLoaderTab("Info",  infoPanel,  2)

    -- Default to login
    activeLoader = loginSetActive
    loginSetActive(true)

    local Loader = {}
    Loader.Frame = loaderFrame
    function Loader:Dismiss()
        Tween(loaderFrame, {Size = UDim2.new(0, 0, 0, 0)}, 0.2)
        task.wait(0.22)
        loaderFrame:Destroy()
    end
    return Loader
end

-- Show watermark by default when first window is opened
Library.SetWatermark = function(self, v)
    WatermarkFrame.Visible = v
end

return Library
