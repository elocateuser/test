        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        ZIndex = 201,
        Parent = valBg,
    })
    Gradient(valGrad, Color3.new(0, 0, 0), Color3.new(1, 1, 1), 0)
    local valCursor = Create("Frame", {
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        Size = UDim2.new(0, 2, 1, 4),
        Position = UDim2.new(1, -2, 0, -2),
        ZIndex = 202,
        Parent = valBg,
    })

    -- Selector dot
    local dot = Create("Frame", {
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
