end

local _notifIdx = 0

local function PushNotif(sg, opts)
    EnsureNotifGui(sg)
    opts = opts or {}
    local title    = opts.Title or "Notification"
    local body     = opts.Content or ""
    local duration = opts.Duration or 4
    local kind     = opts.Type or "Info"
    _notifIdx      = _notifIdx + 1

    local accent = ({
        Info    = T.Accent,
        Success = Color3.fromRGB(52, 199, 89),
        Warning = Color3.fromRGB(255, 184, 0),
        Error   = Color3.fromRGB(255, 59, 48),
    })[kind] or T.Accent

    local card = New("Frame", {
        BackgroundColor3 = T.NotifBg,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0, 0),
        ClipsDescendants = true,
        ZIndex           = 201,
        LayoutOrder      = _notifIdx,
        Parent           = _notifGui,
    })
    Outline(card, T.Border)
    -- left colour bar
    New("Frame", {
        BackgroundColor3 = accent,
        BorderSizePixel  = 0,
        Size             = UDim2.new(0, 2, 1, 0),
        ZIndex           = 202,
        Parent           = card,
    })
    New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 10, 0, 6),
        Size                   = UDim2.new(1, -14, 0, 15),
        Text                   = title,
        TextColor3             = T.Text,
        TextSize               = 12,
        Font                   = Enum.Font.GothamBold,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 202,
        Parent                 = card,
    })
    New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 10, 0, 23),
        Size                   = UDim2.new(1, -14, 0, 26),
        Text                   = body,
        TextColor3             = T.TextDim,
        TextSize               = 10,
        Font                   = Enum.Font.Gotham,
        TextXAlignment         = Enum.TextXAlignment.Left,
        TextWrapped            = true,
        ZIndex                 = 202,
        Parent                 = card,
    })
    -- progress bar
    local pbar = New("Frame", {
        BackgroundColor3 = accent,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 2, 1, -2),
        Size             = UDim2.new(1, -2, 0, 2),
        ZIndex           = 203,
        Parent           = card,
    })

    -- animate in
    TweenService:Create(card,
        TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {Size = UDim2.new(1, 0, 0, 54)}
    ):Play()

    -- progress drain
    TweenService:Create(pbar,
        TweenInfo.new(duration, Enum.EasingStyle.Linear),
        {Size = UDim2.new(0, 0, 0, 2)}
    ):Play()

    -- animate out
    task.delay(duration, function()
        TweenService:Create(card,
            TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            {Size = UDim2.new(1, 0, 0, 0)}
        ):Play()
        task.delay(0.22, function() card:Destroy() end)
    end)
end

