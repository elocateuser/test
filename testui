    Create("Frame", {
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 2),
        ZIndex = 52,
        Parent = loader,
    })

    -- Title row
    local titleRow = Create("Frame", {
        BackgroundColor3 = Theme.BackgroundAlt,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 26),
        Position = UDim2.new(0, 0, 0, 2),
        ZIndex = 52,
        Parent = loader,
    })
    Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 0),
        Size = UDim2.new(1, -8, 1, 0),
        Text = cheatName .. " " .. version,
        TextColor3 = Theme.Text,
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 53,
        Parent = titleRow,
    })
    Create("Frame", {
        BackgroundColor3 = Theme.Border,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        ZIndex = 53,
        Parent = titleRow,
    })

    -- Left sidebar
    local sidebar = Create("Frame", {
        BackgroundColor3 = Theme.BackgroundAlt,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 28),
        Size = UDim2.new(0, 100, 1, -28),
        ZIndex = 52,
        Parent = loader,
    })
    Create("Frame", {
        BackgroundColor3 = Theme.Border,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 1, 1, 0),
        Position = UDim2.new(1, -1, 0, 0),
        ZIndex = 53,
        Parent = sidebar,
    })

    local sidebarTabs = {"Sign In", "Info"}
    local sidebarBtns = {}
    local contentPanels = {}
    local activeSideTab = nil

    for i, tabName in ipairs(sidebarTabs) do
        local btn = Create("TextButton", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 0, 0, (i-1)*32),
            Size = UDim2.new(1, -1, 0, 32),
            Text = "  " .. tabName,
            TextColor3 = Theme.TextDim,
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 53,
            Parent = sidebar,
        })
        -- Active indicator
        local indicator = Create("Frame", {
            BackgroundColor3 = Theme.Accent,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 0, 0, 0),
            Size = UDim2.new(0, 2, 1, 0),
            Visible = false,
            ZIndex = 54,
            Parent = btn,
        })
        table.insert(sidebarBtns, {btn = btn, indicator = indicator})

        -- Content panel
        local panel = Create("Frame", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 102, 0, 28),
            Size = UDim2.new(1, -102, 1, -28),
            Visible = false,
            ZIndex = 52,
            Parent = loader,
        })
        table.insert(contentPanels, panel)

        btn.MouseButton1Click:Connect(function()
            for _, s in ipairs(sidebarBtns) do
                s.btn.TextColor3 = Theme.TextDim
                s.btn.BackgroundTransparency = 1
                s.indicator.Visible = false
            end
            for _, p in ipairs(contentPanels) do p.Visible = false end
            btn.TextColor3 = Theme.Text
            btn.BackgroundColor3 = Theme.TabInactive
            btn.BackgroundTransparency = 0
            indicator.Visible = true
            panel.Visible = true
            activeSideTab = i
        end)
        btn.MouseEnter:Connect(function()
            if activeSideTab ~= i then btn.TextColor3 = Theme.Text end
        end)
        btn.MouseLeave:Connect(function()
            if activeSideTab ~= i then btn.TextColor3 = Theme.TextDim end
        end)
    end

    -- Sign In Panel (index 1)
    local signInPanel = contentPanels[1]
    Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 14),
        Size = UDim2.new(1, 0, 0, 18),
        Text = "Username",
        TextColor3 = Theme.TextDim,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        ZIndex = 53,
        Parent = signInPanel,
    })
    local userInput = Create("TextBox", {
        BackgroundColor3 = Theme.InputBg,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 8, 0, 34),
        Size = UDim2.new(1, -16, 0, 24),
        Text = "",
        PlaceholderText = "Enter username",
        PlaceholderColor3 = Theme.TextDisabled,
        TextColor3 = Theme.Text,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        ClearTextOnFocus = false,
        ZIndex = 53,
        Parent = signInPanel,
    })
    Create("UIPadding", {PaddingLeft = UDim.new(0, 6), Parent = userInput})
    Create("Frame", {BackgroundColor3 = Theme.Border, BorderSizePixel = 0, Size = UDim2.new(1, 2, 1, 2), Position = UDim2.new(0, -1, 0, -1), ZIndex = 52, Parent = userInput})

    Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 64),
        Size = UDim2.new(1, 0, 0, 18),
        Text = "Password",
        TextColor3 = Theme.TextDim,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        ZIndex = 53,
        Parent = signInPanel,
    })
    local passInput = Create("TextBox", {
        BackgroundColor3 = Theme.InputBg,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 8, 0, 84),
        Size = UDim2.new(1, -16, 0, 24),
        Text = "",
        PlaceholderText = "Enter password",
        PlaceholderColor3 = Theme.TextDisabled,
        TextColor3 = Theme.Text,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        ClearTextOnFocus = false,
        ZIndex = 53,
        Parent = signInPanel,
    })
    Create("UIPadding", {PaddingLeft = UDim.new(0, 6), Parent = passInput})
    Create("Frame", {BackgroundColor3 = Theme.Border, BorderSizePixel = 0, Size = UDim2.new(1, 2, 1, 2), Position = UDim2.new(0, -1, 0, -1), ZIndex = 52, Parent = passInput})

    local statusLabel = Create("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 114),
        Size = UDim2.new(1, -16, 0, 16),
        Text = "",
        TextColor3 = Theme.TextDim,
        TextSize = 10,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 53,
        Parent = signInPanel,
    })

    local loginBtn = Create("TextButton", {
        BackgroundColor3 = Theme.Accent,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 8, 0, 134),
        Size = UDim2.new(1, -16, 0, 26),
        Text = "Sign In",
        TextColor3 = Color3.new(1, 1, 1),
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        ZIndex = 53,
        Parent = signInPanel,
    })
    Gradient(loginBtn, Theme.AccentDark, Theme.Accent, 0)

    local exitBtn = Create("TextButton", {
        BackgroundColor3 = Theme.TabInactive,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 8, 0, 164),
        Size = UDim2.new(1, -16, 0, 22),
        Text = "Exit",
        TextColor3 = Theme.TextDim,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        ZIndex = 53,
        Parent = signInPanel,
    })

    loginBtn.MouseButton1Click:Connect(function()
        statusLabel.Text = "Authenticating..."
        statusLabel.TextColor3 = Theme.TextDim
        task.spawn(function()
            local success, msg = pcall(onLogin, userInput.Text, passInput.Text)
            if success and msg then
                statusLabel.Text = "✓ " .. (type(msg) == "string" and msg or "Login successful")
                statusLabel.TextColor3 = Color3.fromRGB(60, 200, 80)
                task.delay(0.8, function()
                    TweenService:Create(loader, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                        Size = UDim2.new(0, 400, 0, 0),
                        BackgroundTransparency = 1,
                    }):Play()
                    task.delay(0.35, function()
                        screenGui:Destroy()
                    end)
                end)
            else
                statusLabel.Text = "✗ " .. tostring(msg or "Login failed")
                statusLabel.TextColor3 = Color3.fromRGB(200, 60, 60)
            end
        end)
