            Name = "Options",
            Size = UDim2.new(1, 0, 0, 0),
            BackgroundColor3 = Theme.Tertiary,
            BorderSizePixel = 0,
            ZIndex = 103,
            ClipsDescendants = true,
            Visible = false,
            Parent = entry
        })
