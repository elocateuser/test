-- ────────────────────────────────────────────────────────────
-- HELPERS
-- ────────────────────────────────────────────────────────────
local function New(cls, props)
    local o = Instance.new(cls)
    for k, v in pairs(props) do
        if k ~= "Parent" then o[k] = v end
    end
    if props.Parent then o.Parent = props.Parent end
    return o
end

-- 1-pixel border frame sitting behind `frame`
local function Outline(frame, color, px)
    px = px or 1
    return New("Frame", {
        BackgroundColor3 = color or T.Border,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, px*2, 1, px*2),
        Position         = UDim2.new(0, -px, 0, -px),
        ZIndex           = math.max(1, frame.ZIndex - 1),
        Parent           = frame.Parent,
    })
end

local function Grad(parent, c1, c2, rot)
    return New("UIGradient", {
        Color    = ColorSequence.new(c1, c2),
        Rotation = rot or 0,
        Parent   = parent,
    })
end

-- Make a frame draggable, optionally gated by canFn()
local function Draggable(frame, handle, canFn)
    local drag, start, origin = false
    handle.InputBegan:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        if canFn and not canFn() then return end
        drag   = true
        start  = i.Position
        origin = frame.Position
    end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - start
            frame.Position = UDim2.new(
                origin.X.Scale, origin.X.Offset + d.X,
                origin.Y.Scale, origin.Y.Offset + d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end)
end

-- ────────────────────────────────────────────────────────────
-- COLOR PICKER  (flat SV square + vertical hue strip + alpha)
-- Logic ported from the reference source; asset IDs kept.
-- ────────────────────────────────────────────────────────────
local function NewColorPicker(parent, defaultColor, defaultAlpha, callback, zbase)
    zbase       = zbase or 60
    defaultAlpha = defaultAlpha or 1

    local hue, sat, val = defaultColor:ToHSV()
    local alpha          = defaultAlpha
    local slidingSV      = false
    local slidingHue     = false
    local slidingAlpha   = false

    -- Popup window
    local win = New("Frame", {
        BackgroundColor3 = Color3.fromRGB(16, 16, 20),
        BorderSizePixel  = 0,
        Size             = UDim2.new(0, 168, 0, 160),
        Visible          = false,
        ZIndex           = zbase,
        Parent           = parent,
    })
    New("Frame", {
        BackgroundColor3 = T.BorderHi,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 2, 1, 2),
        Position         = UDim2.new(0, -1, 0, -1),
        ZIndex           = zbase - 1,
        Parent           = win,
    })

    -- SV square (120×120)
    local svBox = New("TextButton", {
        BackgroundColor3 = Color3.fromHSV(hue, 1, 1),
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 4, 0, 4),
        Size             = UDim2.new(0, 120, 0, 120),
        Text             = "",
        AutoButtonColor  = false,
        ZIndex           = zbase + 1,
        Parent           = win,
    })
    -- saturation overlay (white → transparent, left → right)
    New("ImageLabel", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 1, 0),
        Image                  = "rbxassetid://14684562507",
        ZIndex                 = zbase + 2,
        Parent                 = svBox,
    })
    -- value overlay (transparent → black, top → bottom)
    New("ImageLabel", {
        BackgroundTransparency = 1,
        Size                   = UDim2.new(1, 0, 1, 0),
        Image                  = "rbxassetid://14684563800",
        ZIndex                 = zbase + 3,
        Parent                 = svBox,
    })
    -- cursor dot
    local svDot = New("Frame", {
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel  = 0,
        AnchorPoint      = Vector2.new(0.5, 0.5),
        Size             = UDim2.new(0, 6, 0, 6),
        ZIndex           = zbase + 4,
        Parent           = svBox,
    })

    -- Hue strip (15×120), vertical
    local hueStrip = New("ImageButton", {
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 130, 0, 4),
        Size             = UDim2.new(0, 14, 0, 120),
        Image            = "rbxassetid://14684557999",
        AutoButtonColor  = false,
        ZIndex           = zbase + 2,
        Parent           = win,
    })
    local hueSlide = New("Frame", {
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel  = 0,
        AnchorPoint      = Vector2.new(0, 0.5),
        Size             = UDim2.new(1, 0, 0, 3),
        ZIndex           = zbase + 3,
        Parent           = hueStrip,
    })

    -- Alpha strip (120×10) horizontal, below SV square
    local alphaStrip = New("ImageButton", {
        BackgroundColor3 = Color3.fromHSV(hue, 1, 1),
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 4, 0, 130),
        Size             = UDim2.new(0, 140, 0, 12),
        Image            = "rbxassetid://16841308372",
        AutoButtonColor  = false,
        ZIndex           = zbase + 2,
        Parent           = win,
    })
    local alphaSlide = New("Frame", {
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel  = 0,
        AnchorPoint      = Vector2.new(0.5, 0),
        Size             = UDim2.new(0, 3, 1, 0),
        ZIndex           = zbase + 3,
        Parent           = alphaStrip,
    })

    local function UpdateVisuals()
        -- SV square background = pure hue
        svBox.BackgroundColor3   = Color3.fromHSV(hue, 1, 1)
        alphaStrip.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
        hueSlide.BackgroundColor3   = Color3.fromHSV(hue, 1, 1)

        -- cursor positions
        local sx = math.clamp(1 - sat, 0, 1)
        local sy = math.clamp(1 - val, 0, 1)
        svDot.Position = UDim2.new(sx, 0, sy, 0)

        hueSlide.Position  = UDim2.new(0, 0, math.clamp(hue, 0.005, 0.995), 0)
        alphaSlide.Position = UDim2.new(math.clamp(alpha, 0.005, 0.975), 0, 0, 0)
    end

    local function FireCallback()
        local c = Color3.fromHSV(hue, sat, val)
        pcall(callback, c, alpha)
    end

    local function HandleMouseUpdate()
        local mp = UserInputService:GetMouseLocation()
        -- adjust for CoreGui inset
        local pos = Vector2.new(mp.X, mp.Y - 36)

        if slidingSV then
            local rel = pos - svBox.AbsolutePosition
            sat = math.clamp(1 - rel.X / svBox.AbsoluteSize.X, 0, 1)
            val = math.clamp(1 - rel.Y / svBox.AbsoluteSize.Y, 0, 1)
        elseif slidingHue then
            local rel = pos - hueStrip.AbsolutePosition
            hue = math.clamp(rel.Y / hueStrip.AbsoluteSize.Y, 0, 1)
        elseif slidingAlpha then
            local rel = pos - alphaStrip.AbsolutePosition
            alpha = math.clamp(rel.X / alphaStrip.AbsoluteSize.X, 0, 1)
        end

        UpdateVisuals()
        FireCallback()
    end

    svBox.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            slidingSV = true HandleMouseUpdate()
        end
    end)
    svBox.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then slidingSV = false end
    end)
    hueStrip.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            slidingHue = true HandleMouseUpdate()
        end
    end)
    hueStrip.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then slidingHue = false end
    end)
    alphaStrip.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            slidingAlpha = true HandleMouseUpdate()
        end
    end)
    alphaStrip.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then slidingAlpha = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseMovement then
            if slidingSV or slidingHue or slidingAlpha then HandleMouseUpdate() end
        end
    end)

    UpdateVisuals()

    local picker = {}
    function picker:Set(c, a)
        hue, sat, val = c:ToHSV()
        alpha = a or alpha
        UpdateVisuals()
        FireCallback()
    end
    function picker:GetColor() return Color3.fromHSV(hue, sat, val) end
    function picker:GetAlpha() return alpha end
    function picker:GetWindow() return win end

    return picker
end

