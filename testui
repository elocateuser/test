        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder     = Enum.SortOrder.LayoutOrder,
        Parent        = tabbar,
    })

    -- ── Content ─────────────────────────────────────────────
    local content = New("Frame", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 0, 0, 56),
        Size                   = UDim2.new(1, 0, 1, -56),
        ZIndex                 = 11,
        Parent                 = win,
    })

    -- Toggle
    UserInputService.InputBegan:Connect(function(i, p)
        if p then return end
        if i.KeyCode == menuKey then
            isOpen = not isOpen
            win.Visible = isOpen
            plf.Visible = isOpen
            kbl.Visible = isOpen
        end
    end)

    local tabs      = {}
    local activeTab = nil

    -- ── Window object ────────────────────────────────────────
    local W = {}

    function W:Notify(o) PushNotif(_notifSg, o) end
    function W:ShowPlayerList(v) plf.Visible = v end
    function W:AddKeybindEntry(n, k) AddKb(n, k) end

    function W:AddTab(tabName)
        local idx    = #tabs + 1
        local tabBtn = New("TextButton", {
            BackgroundColor3 = T.BgAlt,
            BorderSizePixel  = 0,
            Size             = UDim2.new(0, 88, 1, 0),
            Text             = tabName,
            TextColor3       = T.TextMuted,
            TextSize         = 11,
            Font             = Enum.Font.GothamBold,
            AutoButtonColor  = false,
            LayoutOrder      = idx,
            ZIndex           = 12,
            Parent           = tabbar,
        })
        -- active indicator (bottom bar)
        local indicator = New("Frame", {
            BackgroundColor3 = T.Accent,
            BorderSizePixel  = 0,
            Size             = UDim2.new(1, 0, 0, 2),
            Position         = UDim2.new(0, 0, 1, -2),
            Visible          = false,
            ZIndex           = 13,
            Parent           = tabBtn,
        })

        -- Tab content = two-column scroll container
        local tabContent = New("Frame", {
            BackgroundTransparency = 1,
            Size                   = UDim2.new(1, 0, 1, 0),
            Visible                = false,
            ZIndex                 = 11,
            Parent                 = content,
        })
        New("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            SortOrder     = Enum.SortOrder.LayoutOrder,
            Parent        = tabContent,
        })

        local tab = {btn = tabBtn, indicator = indicator, frame = tabContent, gradient = nil}
        table.insert(tabs, tab)

        local function Activate()
            if activeTab then
                activeTab.btn.TextColor3        = T.TextMuted
                activeTab.btn.BackgroundColor3  = T.BgAlt
                activeTab.indicator.Visible     = false
                activeTab.frame.Visible         = false
                if activeTab.gradient then activeTab.gradient:Destroy() end
            end
            activeTab = tab
            tabBtn.TextColor3       = T.AccentHi
            tabBtn.BackgroundColor3 = T.Panel
            indicator.Visible       = true
            tab.gradient            = Grad(tabBtn, T.AccentDim, T.Panel, 90)
            tabContent.Visible      = true
        end
        tabBtn.MouseButton1Click:Connect(Activate)
        if idx == 1 then Activate() end

        tabBtn.MouseEnter:Connect(function()
            if activeTab ~= tab then tabBtn.TextColor3 = T.TextDim end
        end)
        tabBtn.MouseLeave:Connect(function()
            if activeTab ~= tab then tabBtn.TextColor3 = T.TextMuted end
        end)

        -- Tab API
        local Tab = {}

        function Tab:AddColumn()
            local col = New("ScrollingFrame", {
                BackgroundTransparency = 1,
                Size                   = UDim2.new(0.5, 0, 1, 0),
                CanvasSize             = UDim2.new(0, 0, 0, 0),
                ScrollBarThickness     = 2,
                ScrollBarImageColor3   = T.Accent,
                BorderSizePixel        = 0,
                LayoutOrder            = #tabContent:GetChildren(),
                ZIndex                 = 11,
                Parent                 = tabContent,
            })
            local cly = New("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding   = UDim.new(0, 0),
                Parent    = col,
            })
            cly:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                col.CanvasSize = UDim2.new(0, 0, 0, cly.AbsoluteContentSize.Y + 8)
            end)
            local Col = {}
            function Col:AddSection(name)
                return MakeSection(name, col, 12)
            end
            return Col
        end

        -- Convenience: single column shortcut
        function Tab:AddSection(name)
            -- if no columns yet, auto-create one full-width
            local fc = tabContent:FindFirstChildOfClass("ScrollingFrame")
            if not fc then
                local c = Tab:AddColumn()
                fc = tabContent:FindFirstChildOfClass("ScrollingFrame")
                -- make it full width
                if fc then fc.Size = UDim2.new(1, 0, 1, 0) end
            end
            return MakeSection(name, fc, 12)
        end

        return Tab
    end

    return W
end

