        BackgroundColor3 = defaultColor,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 10, 0, SIZE + 34),
        Size = UDim2.new(0, SIZE, 0, 18),
        ZIndex = 201,
        Parent = pickerFrame,
    })

    local H, S, V = defaultColor:ToHSV()
    local draggingWheel = false
    local draggingVal = false

    local function updateColor()
        local r, g, b = HSVtoRGB(H, S, V)
        local c = Color3.new(r, g, b)
        preview.BackgroundColor3 = c
        valGrad.BackgroundColor3 = Color3.fromHSV(H, S, 1)
        if callback then callback(c) end
    end

    wheel.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWheel = true
        end
    end)
    valBg.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingVal = true
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingWheel = false
            draggingVal = false
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        if draggingWheel then
            local abs = wheel.AbsolutePosition
            local sz = wheel.AbsoluteSize
            local mx = math.clamp((inp.Position.X - abs.X) / sz.X, 0, 1)
            local my = math.clamp((inp.Position.Y - abs.Y) / sz.Y, 0, 1)
            local cx = mx - 0.5
            local cy = my - 0.5
            local dist = math.sqrt(cx*cx + cy*cy)
            S = math.min(dist * 2, 1)
            H = (math.atan2(cy, cx) / (2 * math.pi) + 0.5) % 1
            dot.Position = UDim2.new(0, abs.X - pickerFrame.AbsolutePosition.X + mx*sz.X - 4, 0, abs.Y - pickerFrame.AbsolutePosition.Y + my*sz.Y - 4)
            updateColor()
        end
        if draggingVal then
            local abs = valBg.AbsolutePosition
            local sz = valBg.AbsoluteSize
            local mx = math.clamp((inp.Position.X - abs.X) / sz.X, 0, 1)
            V = mx
            valCursor.Position = UDim2.new(mx, -2, 0, -2)
            updateColor()
        end
    end)

    updateColor()
    return pickerFrame
end

