        })
        AddGradient(hpFill, ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 220, 100)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(40, 160, 40))
        }), 0)

        -- Update HP
        local char = player.Character or player.CharacterAdded:Wait()
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                local function updateHP()
                    local pct = hum.Health / math.max(hum.MaxHealth, 1)
                    hpFill.Size = UDim2.new(math.clamp(pct, 0, 1), 0, 1, 0)
                    local r = math.floor((1 - pct) * 200)
                    local g = math.floor(pct * 200)
                    hpFill.BackgroundColor3 = Color3.fromRGB(r, g, 40)
                end
                updateHP()
                hum:GetPropertyChangedSignal("Health"):Connect(updateHP)
            end
