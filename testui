                    entry.Size = UDim2.new(1, 0, 0, 44)
                end
                plScroll.CanvasSize = UDim2.new(0, 0, 0, plLayout.AbsoluteContentSize.Y + 4)
            end
        end)

        table.insert(playerEntries, {entry = entry, player = player})
    end
    plScroll.CanvasSize = UDim2.new(0, 0, 0, plLayout.AbsoluteContentSize.Y + 4)
end

