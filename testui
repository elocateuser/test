                        Parent           = row,
                    })
                    row.Size = UDim2.new(1, 0, 0, 126)
                    local actions = {
                        {"Teleport", function()
                            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and
                               LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                                LocalPlayer.Character.HumanoidRootPart.CFrame =
                                    p.Character.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
                            end
                        end},
                        {"Spectate", function()
                            workspace.CurrentCamera.CameraSubject =
                                (p.Character and p.Character:FindFirstChildOfClass("Humanoid"))
                                or workspace.CurrentCamera.CameraSubject
                        end},
                        {"Copy Name",    function() pcall(setclipboard, p.Name) end},
                        {"Profile Link", function() pcall(setclipboard, "https://www.roblox.com/users/" .. p.UserId .. "/profile") end},
                    }
                    for ai, ac in ipairs(actions) do
                        local btn = New("TextButton", {
                            BackgroundColor3 = T.BgAlt,
                            BorderSizePixel  = 0,
                            Position         = UDim2.new(0, 4, 0, (ai-1)*21 + 4),
                            Size             = UDim2.new(1, -8, 0, 19),
                            Text             = ac[1],
                            TextColor3       = T.TextDim,
                            TextSize         = 10,
                            Font             = Enum.Font.Gotham,
                            ZIndex           = 95,
                            Parent           = optFrame,
                        })
                        btn.MouseEnter:Connect(function()
                            btn.BackgroundColor3 = T.AccentDim
                            btn.TextColor3 = T.Text
                        end)
                        btn.MouseLeave:Connect(function()
                            btn.BackgroundColor3 = T.BgAlt
                            btn.TextColor3 = T.TextDim
                        end)
                        btn.MouseButton1Click:Connect(function() pcall(ac[2]) end)
                    end
                else
                    if optFrame then optFrame:Destroy() optFrame = nil end
                    row.Size = UDim2.new(1, 0, 0, 38)
                end
            end)
        end
    end

    Build()
    Players.PlayerAdded:Connect(function() task.wait(0.1) Build() end)
    Players.PlayerRemoving:Connect(function() task.wait(0.1) Build() end)

    Draggable(pl, hdr, openFn)
    return pl
end

