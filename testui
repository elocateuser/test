    local owners = options.Owners or {"Owner"}
    local discordLink = options.Discord or "https://discord.gg/elocate"
    local onLogin = options.OnLogin or function(user, pass) return true, "Success" end

    local screenGui = Create("ScreenGui", {
        Name = "elocateLoader",
