local function MakeWatermark(sg, openFn)
    local wm = New("Frame", {
        Name             = "Watermark",
        BackgroundColor3 = T.WmBg,
        BorderSizePixel  = 0,
        Position         = UDim2.new(0, 8, 0, 8),
        Size             = UDim2.new(0, 10, 0, 20),
        ZIndex           = 95,
        Parent           = sg,
    })
    Outline(wm, T.Border)
    -- top accent line
    New("Frame", {
        BackgroundColor3 = T.Accent,
        BorderSizePixel  = 0,
        Size             = UDim2.new(1, 0, 0, 1),
        ZIndex           = 96,
        Parent           = wm,
    })
    local lbl = New("TextLabel", {
        BackgroundTransparency = 1,
        Position               = UDim2.new(0, 7, 0, 0),
        Size                   = UDim2.new(1, -10, 1, 0),
        Text                   = "elocate.lol",
        TextColor3             = T.TextDim,
        TextSize               = 11,
        Font                   = Enum.Font.Gotham,
        TextXAlignment         = Enum.TextXAlignment.Left,
        ZIndex                 = 96,
        Parent                 = wm,
    })

    -- Update fps/ping live
    local lastFps, lastPing = 0, 0
    local frameCount, frameTimer = 0, 0
    RunService.RenderStepped:Connect(function(dt)
        frameCount = frameCount + 1
        frameTimer = frameTimer + dt
        if frameTimer >= 0.5 then
            lastFps   = math.floor(frameCount / frameTimer)
            frameCount = 0
            frameTimer = 0
            pcall(function()
                lastPing = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            end)
            local t = string.format(
                "elocate.lol  |  fps: %d  |  ping: %dms  |  userid: %d",
                lastFps, lastPing, LocalPlayer.UserId)
            lbl.Text = t
            -- auto-size
            local tw = game:GetService("TextService"):GetTextSize(
                t, 11, Enum.Font.Gotham, Vector2.new(9999, 20)).X
            wm.Size = UDim2.new(0, tw + 14, 0, 20)
        end
    end)

    Draggable(wm, wm, openFn)
    return wm
end

