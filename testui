    }
    local accentColor = colors[ntype] or colors.info

    local notif = Create("Frame", {
        Name = "Notification",
        Size = UDim2.new(1, 0, 0, 70),
        BackgroundColor3 = Theme.Notification,
        BorderSizePixel = 0,
        ClipsDescendants = true,
