            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0, 2),
            Parent = optionsFrame
        })
        Create("UIPadding", {PaddingTop = UDim.new(0,4), PaddingBottom = UDim.new(0,4), Parent = optionsFrame})

        local optButtons = {
            {name = "Teleport", icon = "rbxassetid://6031229517"},
            {name = "Spectate", icon = "rbxassetid://6031229517"},
            {name = "Copy UserID", icon = "rbxassetid://6031229517"},
            {name = "Highlight", icon = "rbxassetid://6031229517"},
        }
        for i, opt in ipairs(optButtons) do
            local optBtn = Create("TextButton", {
                Size = UDim2.new(1, -8, 0, 22),
                BackgroundColor3 = Theme.Secondary,
                BorderSizePixel = 0,
                Text = opt.name,
                TextColor3 = Theme.Text,
                TextSize = 11,
                Font = Enum.Font.Gotham,
                ZIndex = 105,
                LayoutOrder = i,
                Parent = optionsFrame
            })
            Create("UIPadding", {PaddingLeft = UDim.new(0, 4), Parent = optBtn})
            optBtn.MouseEnter:Connect(function()
                Tween(optBtn, {BackgroundColor3 = Theme.Tertiary}, 0.1)
            end)
            optBtn.MouseLeave:Connect(function()
                Tween(optBtn, {BackgroundColor3 = Theme.Secondary}, 0.1)
            end)
            optBtn.MouseButton1Click:Connect(function()
                if opt.name == "Teleport" then
                    local char2 = player.Character
                    if char2 and LocalPlayer.Character then
                        local root = char2:FindFirstChild("HumanoidRootPart")
                        local lroot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if root and lroot then
                            lroot.CFrame = root.CFrame + Vector3.new(3, 0, 0)
                        end
                    end
                elseif opt.name == "Copy UserID" then
                    setclipboard(tostring(player.UserId))
                    Library:Notify("Copied", "UserID copied: "..player.UserId, 2, "info")
                elseif opt.name == "Spectate" then
                    workspace.CurrentCamera.CameraSubject = (player.Character and player.Character:FindFirstChildOfClass("Humanoid")) or workspace.CurrentCamera.CameraSubject
                    Library:Notify("Spectating", "Now spectating "..player.Name, 3, "info")
                elseif opt.name == "Highlight" then
                    if player.Character then
                        local existing = player.Character:FindFirstChild("elocateHL")
                        if existing then
                            existing:Destroy()
                            Library:Notify("Highlight", "Removed highlight from "..player.Name, 2, "info")
                        else
                            local hl = Instance.new("SelectionBox")
                            hl.Name = "elocateHL"
                            hl.Adornee = player.Character
                            hl.Color3 = Theme.Accent
                            hl.LineThickness = 0.05
                            hl.SurfaceTransparency = 0.7
                            hl.SurfaceColor3 = Theme.Accent
                            hl.Parent = player.Character
                            Library:Notify("Highlight", "Highlighting "..player.Name, 2, "success")
                        end
                    end
                end
            end)
        end

        local expanded = false
        entry.InputBegan:Connect(function(inp)
